{
  "title": "Churn Prediction API Monitoring",
  "uid": "churn-api",
  "panels": [
    {
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [{"expr": "predictions_total", "refId": "A"}]
    },
    {
      "title": "Predictions Per Minute",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 10, "x": 6, "y": 0},
      "datasource": "Prometheus",
      "targets": [{"expr": "rate(predictions_total[1m]) * 60", "legendFormat": "req/min", "refId": "A"}]
    },
    {
      "title": "Churn Rate",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "datasource": "Prometheus",
      "targets": [{"expr": "churn_predicted_total{prediction=\"churn\"} / predictions_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"max": 1, "min": 0, "unit": "percentunit"}}
    },
    {
      "title": "Prediction Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))", "legendFormat": "P99", "refId": "C"}
      ]
    },
    {
      "title": "Churn vs Retain Predictions",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 6},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "churn_predicted_total{prediction=\"churn\"}", "legendFormat": "Churn", "refId": "A"},
        {"expr": "churn_predicted_total{prediction=\"retain\"}", "legendFormat": "Retain", "refId": "B"}
      ]
    },
    {
      "title": "Probability Distribution",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 6},
      "datasource": "Prometheus",
      "targets": [{"expr": "prediction_probability_bucket", "refId": "A"}]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "schemaVersion": 30
}
